{
  "expo": {
    "name": "WasteSmart",
    "slug": "wastesmart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1D9E75"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wastesmart.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D9E75"
      },
      "package": "com.wastesmart.app",
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow WasteSmart to use your camera for QR scanning."
        }
      ]
    ],
    "scheme": "wastesmart",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c5a7a92b-1772-45aa-aa74-8379b1f18f30"
      }
    }
  }
}
